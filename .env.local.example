# ============================================
# GMLB Site — переменные окружения
# Скопируйте этот файл в .env.local и заполните
# ============================================

# PostgreSQL (обязательно)
DATABASE_URI=postgresql://gmlb_user:your_password@localhost:5432/gmlb_db

# Payload CMS (обязательно — любая случайная строка ≥ 32 символа)
PAYLOAD_SECRET=change-this-to-a-random-secret-string-at-least-32-chars

# URL сайта (обязательно в production)
NEXT_PUBLIC_SITE_URL=https://yourdomain.ru

# Telegram уведомления о заявках
# ВАЖНО: токен задаётся ТОЛЬКО здесь — НЕ в админке CMS
# Получить токен: @BotFather → /newbot
# Получить chat_id: @userinfobot или @getmyid_bot
TELEGRAM_BOT_TOKEN=123456789:AABBCCDDEEFFaabbccddeeff
TELEGRAM_CHAT_ID=-1001234567890

# Node environment
NODE_ENV=production
